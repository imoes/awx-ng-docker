# awx-ng — Konfiguration
# cp .env.example .env  und Werte eintragen

# ── AWX Admin-Login ──────────────────────────────────────────────────────────
AWX_ADMIN_PASSWORD=changeme

# ── Ansible-Repo ─────────────────────────────────────────────────────────────
# Pfad zum lokalen Ansible-Repository (wird read-write in die Container gemountet)
ANSIBLE_REPO_PATH=/path/to/your/ansible/repo

# ── NetBox-Integration (optional) ────────────────────────────────────────────
# Für Location/Subnet-Reconcile und NetBox-Inventory-Source
NETBOX_URL=https://netbox.example.com
NETBOX_TOKEN=

# ── OIDC/SSO via Keycloak (optional) ─────────────────────────────────────────
# Alle drei setzen oder alle drei leer lassen.
# Keycloak-Setup: Client "awx-ng" anlegen (confidential),
# Redirect URI: http://<awx-host>:8052/sso/complete/oidc/
OIDC_ENDPOINT=https://keycloak.example.com/auth/realms/<realm>
OIDC_KEY=awx-ng
OIDC_SECRET=
OIDC_VERIFY_SSL=true
