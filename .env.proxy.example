# Remote execution node configuration
# Copy to a local file and pass values to setup-proxy.sh:
#
#   PROXY_NODE_ID=ansible03 \
#   AWX_NG_CONTROL_HOST=awx-ng.example.com \
#   AWX_NG_CONTROL_PORT=2222 \
#   ./scripts/setup-proxy.sh "$PROXY_NODE_ID" "$AWX_NG_CONTROL_HOST" "$AWX_NG_CONTROL_PORT"
#
# Or pass arguments directly:
#   ./scripts/setup-proxy.sh ansible03 awx-ng.example.com 2222

PROXY_NODE_ID=ansible03
AWX_NG_CONTROL_HOST=awx-ng.example.com
AWX_NG_CONTROL_PORT=2222
