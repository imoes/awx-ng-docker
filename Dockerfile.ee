# awx-ng Execution Environment
# Basis: offizielles AWX EE 24.6.1
# AWX_DISABLE_CONTAINER_ISOLATION=True: ansible-runner läuft direkt in diesem Container.

FROM ghcr.io/ansible/awx-ee:24.6.1

USER root

# Ansible Collections aus lokal vorgehaltenen Tarballs installieren.
# Kein Netzwerkzugriff nötig — Galaxy-API ist häufig instabil (HTTP 500).
# Tarballs liegen in deploy/collections/ und werden mit dem Build-Context kopiert.
COPY collections/netbox-netbox-3.20.0.tar.gz     /tmp/collections/
COPY collections/community-general-10.7.0.tar.gz  /tmp/collections/

RUN pip install pynetbox requests && \
    ansible-galaxy collection install \
        /tmp/collections/netbox-netbox-3.20.0.tar.gz \
        /tmp/collections/community-general-10.7.0.tar.gz \
        --collections-path /usr/share/ansible/collections && \
    rm -rf /tmp/collections

# Receptor-Socket-Verzeichnis sicherstellen
RUN mkdir -p /var/run/receptor && chmod 777 /var/run/receptor
